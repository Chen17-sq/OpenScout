# DB — defaults to local SQLite. Production uses Postgres + pgvector:
#   DATABASE_URL=postgresql+psycopg://openscout:openscout_dev@localhost:5433/openscout
DATABASE_URL=sqlite:///./openscout.db

# Anthropic — used for topic classification + 中文一句话
ANTHROPIC_API_KEY=sk-ant-...

# Semantic Scholar — optional, raises rate limit from 100/5min to 1k/5min
SEMANTIC_SCHOLAR_API_KEY=

# Resend — daily email digest (v2)
RESEND_API_KEY=
NOTIFY_EMAIL_TO=

# Admin secret — GitHub Actions cron uses this to call /admin/ingest
INGEST_SECRET=change-me-to-a-long-random-string

# CORS — frontend origin
FRONTEND_ORIGIN=http://localhost:5174
